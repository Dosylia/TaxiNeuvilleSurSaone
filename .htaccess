RewriteEngine On

# Redirect index.php, index.html, or index.phtml to the site root
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.(php|html|phtml)\ HTTP/
RewriteRule ^index\.(php|html|phtml)$ / [R=301,L]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Remove .php, .phtml, and .html extensions from URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)\.(php|phtml|html)$ /$1 [R=301,L]

# Internally rewrite extensionless URLs to the correct file
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

RewriteCond %{REQUEST_FILENAME}.phtml -f
RewriteRule ^(.+)$ $1.phtml [L]

RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]